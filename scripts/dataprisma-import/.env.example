# ── Origem: Dataprisma (MySQL) ───────────────────────────────────────────────
SRC_HOST=51.79.21.221
SRC_PORT=3306
SRC_USER=peoutdoor_ruan
SRC_PASS=<senha-select-only>
SRC_DB=peoutdoor_site_dataprisma

# Tabela de origem (viva, ~170k pontos). backup_pontos_2025 = snapshot 2025 (152k).
SOURCE_TABLE=out785_pontos
SOURCE_UF_COL=area

# Tabelas de lookup (resolvidas em memória durante o import)
CITY_TABLE=out785_pontos_cidades
TYPE_TABLE=out785_pontos_tipos

# Base das fotos. {UF} é substituído pela area do ponto.
# Padrão confirmado: https://scoutdoor.com.br/imagem/SC/pontos/<arquivo>
PHOTO_BASE_URL=https://scoutdoor.com.br/imagem/{UF}/pontos

# ── Destino: InteliONE (PostgreSQL 16) ───────────────────────────────────────
# Conecta DIRETO na 5432 (bypassa PgBouncer/6432 — ver gotcha no CLAUDE.md).
DST_HOST=localhost
DST_PORT=5432
DST_USER=flowdesk_user
DST_PASS=<senha-postgres-local>
DST_DB=flowdesk

# ── Mapeamento area → department_id (multi-tenancy) ──────────────────────────
# Obtenha os UUIDs com:
#   SELECT id, name FROM departments WHERE archived_at IS NULL ORDER BY name;
# Areas ausentes ficam com department_id = NULL (ativo compartilhado/holding).
# Ex.: SC → SC Outdoor
DEPT_MAP={"SC":"7ec68ab5-d687-4305-956f-ba468fcbadb3"}
