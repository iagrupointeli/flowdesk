{
  "name": "flowdesk-backend",
  "version": "1.0.0",
  "description": "FlowDesk API",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --env-file=../.env --watch src/index.js",
    "start": "node --env-file=../.env src/index.js",
    "migrate": "node --env-file=../.env src/migrations/run.js",
    "seed": "node --env-file=../.env src/seeders/run.js"
  },
  "imports": {
    "#config/*.js": "./src/config/*.js",
    "#controllers/*.js": "./src/controllers/*.js",
    "#services/*.js": "./src/services/*.js",
    "#routes/*.js": "./src/routes/*.js",
    "#middlewares/*.js": "./src/middlewares/*.js",
    "#models/*.js": "./src/models/*.js",
    "#utils/*.js": "./src/utils/*.js",
    "#lib/*.js": "./src/lib/*.js",
    "#socket/*.js": "./src/socket/*.js"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bcrypt": "^5.1.1",
    "busboy": "^1.6.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "file-type": "^19.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "minio": "^8.0.1",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.19.1",
    "pg": "^8.12.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pino-pretty": "^13.1.3"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  }
}
